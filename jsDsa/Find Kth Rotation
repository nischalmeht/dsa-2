/**
 * @param {number[]} arr
 * @returns {number}
 */
class Solution {
    findKRotation(arr) {
        // Code Here
        let left=0
        let right=arr.length-1
        while(left<right){
            let mid=Math.floor((left + right)/2);
            if(arr[mid]>arr[right]){
                left = mid+1
            }else{
                right=mid
            }
        }
        return left
    }
}
