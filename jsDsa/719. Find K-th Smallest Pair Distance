/**
 * @param {number[]} nums
 * @param {number} k
 * @return {number}
 */
var smallestDistancePair = function(nums, k) {
    nums.sort((a,b)=>a-b)
    let left =0
    let n= nums.length 
    function canPair(k){
        let l=0
        let count =0
        for(let r=0;r<n;r++){
            if(nums[r]-nums[l]>k){
                l++

            }        
                count+=(r-l)
        }
        return count
    }
    let right = nums[n-1] - nums[0]
    while(left<=right){
        let mid =Math.floor((left+right)/2)
        if(canPair(mid)>=k){
            right = mid -1
        }else{
            left = mid + 1
        }
    }
    return left
};
