var calculate = function(s) {
    let stack = [];
    let num = 0;
    let sign = "+";

    for (let i = 0; i < s.length; i++) {
        let ch = s[i];

        if (!isNaN(ch) && ch !== " ") {
            num = num * 10 + Number(ch);
        }

        if ((isNaN(ch) && ch !== " ") || i === s.length - 1) {

            if (sign === "+") {
                stack.push(num);
            } 
            else if (sign === "-") {
                stack.push(-num);
            } 
            else if (sign === "*") {
                stack.push(stack.pop() * num);
            } 
            else if (sign === "/") {
                stack.push(Math.trunc(stack.pop() / num));
            }

            sign = ch;
            num = 0;
        }
    }

    return stack.reduce((a, b) => a + b, 0);
};
