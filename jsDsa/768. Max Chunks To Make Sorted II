/**
 * @param {number[]} arr
 * @return {number}
 */
var maxChunksToSorted = function(arr) {
    let n= arr.length
    let maxLeft=Array(n);
    let minRight=Array(n+1);
    maxLeft[0]=arr[0]
    for(let i=1;i<n;i++){
        maxLeft[i]=Math.max(maxLeft[i-1],arr[i])
    }
    minRight[n]=Infinity
        for(let i=n-1;i>=0;i--){
        minRight[i]=Math.min(minRight[i+1],arr[i])
    }
    let chunk=0
    for(let i=0;i<n;i++){
        if(maxLeft[i]<=minRight[i+1]) chunk++
    }
    return chunk
};
