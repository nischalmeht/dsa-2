/**
 * @param {number[]} piles
 * @param {number} h
 * @return {number}
 */
var minEatingSpeed = function(piles, h) {
  let left=1
  let right=Math.max(...piles)
  while(left<=right){
    let mid=Math.floor((left+right)/2)
    let hr=0
    for(let num of piles){
        hr+=Math.ceil(num/mid)
    }
    if(hr>h){
        left=mid+1
    }else{
        right=mid-1
    }
  }
  return left
};
