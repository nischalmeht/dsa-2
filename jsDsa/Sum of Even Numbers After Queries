/**
 * @param {number[]} nums
 * @param {number[][]} queries
 * @return {number[]}
 */
var sumEvenAfterQueries = function(nums, queries) {
    let sum =0
    let res = []
    for(let num of nums){
        if(num%2==0)
        sum +=num
    }
    for(let [val,index] of queries){
        if(nums[index]%2==0) sum-= nums[index]
        nums[index]+=val
        if(nums[index]%2==0) sum+=nums[index]
        res.push(sum)
    }
    return res
};
