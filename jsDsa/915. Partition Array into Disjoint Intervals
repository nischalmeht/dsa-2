/**
 * @param {number[]} nums
 * @return {number}
 */
var partitionDisjoint = function(nums) {
    let leftMax=nums[0]
    let globalMax=nums[0]
    let partitionIdx=0
    for(let i=1;i<nums.length;i++){
        globalMax=Math.max(nums[i],globalMax)
        if(nums[i]<leftMax){
            partitionIdx=i
            leftMax=globalMax
        }
    }
    return partitionIdx +1
};
