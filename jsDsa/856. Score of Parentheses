/**
 * @param {string} s
 * @return {number}
 */
var scoreOfParentheses = function(s) {
    let score =0
    let dept =0
    for(let i=0;i<s.length;i++){
        if(s[i]=='('){
            dept++
        }else{
            dept--
            if(s[i-1]=='('){
                score+= Math.pow(2,dept)
            }
        }
    }
    return score
};
