/**
 * @param {string} s
 * @return {number}
 */
var minimumLength = function(s) {
    let left=0
    let right=s.length-1
    while(left<right && s[left]==s[right]){
    let ch=s[left]
    while(left<=right && s[left]==ch){
    left++
    }
    while(left<=right && s[right]==ch){
    right--
    }

    }
    return right-left+1>0? right-left+1 :0
};
