class Solution {
    kToppers(arr, k) {
        // Your Code goes here.
        let map= new Map()
        for(let i=0;i<arr.length;i++){
            if(!map.get(arr[i])) map.set(arr[i],[])
            map.get(arr[i]).push(i)
        }
        let marks = [...map.keys()].sort((a,b)=>b-a);
        let res=[]
        for(let i=0;i<k;i++){
            res.push(...map.get(marks[i]))
        }
        return res
    }
}
